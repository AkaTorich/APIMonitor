<Window x:Class="APIMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:APIMonitor.ViewModel"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="APIMonitor"
        Height="720" Width="1280"
        Background="{StaticResource BgBrush}"
        Foreground="{StaticResource FgBrush}"
        FontFamily="Cascadia Mono, Consolas"
        FontSize="12"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="False">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="28"
                            ResizeBorderThickness="6"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False"
                            CornerRadius="0"/>
    </shell:WindowChrome.WindowChrome>

    <Border BorderBrush="#FFFF00" BorderThickness="1">
        <!-- Когда WindowStyle="None"+WindowChrome максимизирован, Windows
             расширяет окно за пределы work area на ~8px - наш контент по
             краям обрезается. Компенсируем margin'ом только в Maximized. -->
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Margin" Value="0"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}" Value="Maximized">
                        <Setter Property="Margin" Value="8"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
    <DockPanel LastChildFill="True">

        <!-- Custom title bar -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Height="28">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: prompt-like title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="10,0,0,0">
                    <TextBlock Text="[ "      Foreground="{StaticResource AccentBrush}" FontWeight="Bold"/>
                    <TextBlock Text="apimon"  Foreground="{StaticResource FgBrush}"     FontWeight="Bold">
                        <TextBlock.Effect>
                            <DropShadowEffect ShadowDepth="0" BlurRadius="6" Color="#33FF99" Opacity="0.9"/>
                        </TextBlock.Effect>
                    </TextBlock>
                    <TextBlock Text=" @ "     Foreground="{StaticResource DimBrush}"/>
                    <TextBlock Text="win32"   Foreground="{StaticResource AccentBrush}"/>
                    <TextBlock Text=" ]"      Foreground="{StaticResource AccentBrush}" FontWeight="Bold"/>
                    <TextBlock Text=" :: "    Foreground="{StaticResource DimBrush}"/>
                    <TextBlock Text="API tracer" Foreground="{StaticResource DimBrush}"/>
                </StackPanel>

                <!-- Right: window controls (min, max, close) -->
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            VerticalAlignment="Stretch"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button x:Name="MinButton"
                            Content="—"
                            Width="40" MinWidth="0"
                            BorderThickness="0,0,1,0"
                            Padding="0"
                            FontSize="14"
                            Click="MinButton_Click"/>
                    <Button x:Name="MaxButton"
                            Content="□"
                            Width="40" MinWidth="0"
                            BorderThickness="0,0,1,0"
                            Padding="0"
                            FontSize="14"
                            Click="MaxButton_Click"/>
                    <Button x:Name="CloseButton"
                            Content="✕"
                            Width="40" MinWidth="0"
                            BorderThickness="0"
                            Padding="0"
                            FontSize="14"
                            Foreground="{StaticResource AlertBrush}"
                            Click="CloseButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Top bar: target path, browse, run/stop, filter -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Label Grid.Column="0" Content="Target .exe:" VerticalAlignment="Center"/>
                <TextBox  Grid.Column="1"
                          Margin="6,0,6,0"
                          VerticalContentAlignment="Center"
                          Text="{Binding TargetPath, UpdateSourceTrigger=PropertyChanged}"
                          IsEnabled="{Binding CanEditTarget}"/>
                <Button Grid.Column="2"
                        Content="Browse..."
                        Margin="0,0,6,0"
                        Command="{Binding BrowseCommand}"/>
                <Button Grid.Column="3"
                        Content="{Binding RunStopText}"
                        Margin="0,0,12,0"
                        Command="{Binding RunStopCommand}"/>

                <Label Grid.Column="4" Content="Filter:" VerticalAlignment="Center"/>
                <ComboBox Grid.Column="5"
                          Width="120"
                          VerticalContentAlignment="Center"
                          ItemsSource="{Binding FilterOptions}"
                          SelectedItem="{Binding SelectedFilter}"/>
                <Button Grid.Column="6"
                        Content="Clear"
                        Margin="6,0,0,0"
                        Command="{Binding ClearCommand}"/>
            </Grid>
        </Border>

        <!-- Status bar -->
        <StatusBar DockPanel.Dock="Bottom" Height="24">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock>
                    <Run Text="Events: "/>
                    <Run Text="{Binding TotalCount, Mode=OneWay}"/>
                    <Run Text="  Visible: "/>
                    <Run Text="{Binding VisibleCount, Mode=OneWay}"/>
                    <Run Text="  Dropped: "/>
                    <Run Text="{Binding DroppedCount, Mode=OneWay}"/>
                </TextBlock>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="{Binding DriverStatus}"/>
            </StatusBarItem>
        </StatusBar>

        <!-- Main grid with events -->
        <DataGrid ItemsSource="{Binding VisibleEvents}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="True"
                  HeadersVisibility="Column"
                  GridLinesVisibility="None"
                  RowHeight="18"
                  Background="{StaticResource BgBrush}"
                  Foreground="{StaticResource FgBrush}"
                  BorderThickness="0"
                  EnableRowVirtualization="True"
                  EnableColumnVirtualization="True"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  VirtualizingPanel.ScrollUnit="Item"
                  ScrollViewer.CanContentScroll="True"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                  ScrollViewer.VerticalScrollBarVisibility="Auto">

            <DataGrid.Resources>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
                    <Setter Property="Foreground" Value="{StaticResource FgBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                    <Setter Property="Padding" Value="6,2"/>
                </Style>
                <Style TargetType="DataGridRow">
                    <Setter Property="Background" Value="{StaticResource BgBrush}"/>
                    <Setter Property="Foreground" Value="{StaticResource FgBrush}"/>
                </Style>
                <Style TargetType="DataGridCell">
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Padding" Value="6,1"/>
                </Style>
            </DataGrid.Resources>

            <DataGrid.Columns>
                <DataGridTextColumn Header="#"        Binding="{Binding Index}"     Width="60"/>
                <DataGridTextColumn Header="PID"      Binding="{Binding Pid}"       Width="60"/>
                <DataGridTextColumn Header="TID"      Binding="{Binding Tid}"       Width="60"/>
                <DataGridTextColumn Header="Function" Binding="{Binding Function}"  Width="180"/>
                <DataGridTextColumn Header="Args"     Binding="{Binding Args}"      Width="*"/>
                <DataGridTextColumn Header="Ret"      Binding="{Binding Ret}"       Width="180"/>
                <DataGridTextColumn Header="Caller"   Binding="{Binding CallerModule}" Width="240"/>
            </DataGrid.Columns>
        </DataGrid>

    </DockPanel>
    </Border>
</Window>
